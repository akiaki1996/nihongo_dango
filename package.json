{
  "name": "nihon-class",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build && tsc --project tsconfig.seed.json",
    "start": "node dist-seed/src/scripts/seed.js && npx next start -p ${PORT:-3000}",
    "seed": "tsx src/scripts/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "next": "14.2.5",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "better-sqlite3": "11.1.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.10",
    "@types/node": "20.14.10",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "typescript": "5.5.3",
    "tsx": "4.16.2",
    "vitest": "2.0.3"
  }
}
